#!/usr/bin/env bash
set -euo pipefail

CONFIG="${CCRUN_CONFIG:-$HOME/.config/ccrun/sessions.json}"
SUBCMD="${1:-launch}"

usage() {
  cat <<EOF
ccrun — Claude Code session launcher for iTerm2

Usage:
  ccrun [launch]                       Launch all sessions from config
  ccrun list                           List configured sessions
  ccrun add <name> <path> [<resume>]   Append a new session to config
  ccrun remove <name>                  Remove a session by name
  ccrun eco                            Open config in TextMate
  ccrun edit                           Open config in \$EDITOR
  ccrun path                           Print config file path

Config: \$CCRUN_CONFIG or ~/.config/ccrun/sessions.json
EOF
}

require_jq() {
  command -v jq >/dev/null || {
    echo "ccrun: jq required (brew install jq)" >&2
    exit 1
  }
}

require_config() {
  if [[ ! -f "$CONFIG" ]]; then
    echo "ccrun: no config at $CONFIG" >&2
    echo "run 'ccrun add <name> <path> [<resume>]' to create one" >&2
    exit 1
  fi
}

ensure_config_dir() {
  mkdir -p "$(dirname "$CONFIG")"
  if [[ ! -f "$CONFIG" ]]; then
    echo '{"version":1,"defaults":{"command":"ccb"},"sessions":[]}' > "$CONFIG"
  fi
}

cmd_launch() {
  require_jq
  require_config

  local count total
  total=$(jq '.sessions | length' "$CONFIG")
  count=$(jq '[.sessions[] | select(.run != false)] | length' "$CONFIG")
  if [[ "$total" -eq 0 ]]; then
    echo "ccrun: no sessions in config"
    exit 0
  fi
  if [[ "$count" -eq 0 ]]; then
    echo "ccrun: all $total session(s) paused (run:false) — nothing to launch"
    exit 0
  fi

  local base_cmd
  base_cmd=$(jq -r '.defaults.command // "ccb"' "$CONFIG")

  # Generate JXA via Python, pipe directly to osascript
  python3 - "$CONFIG" "$base_cmd" <<'PYEOF' | osascript -l JavaScript >/dev/null
import json, os, sys

config_path, base_cmd = sys.argv[1], sys.argv[2]
with open(config_path) as f:
    sessions = [s for s in json.load(f).get("sessions", []) if s.get("run", True) is not False]

def js_esc(s):
    return s.replace("\\", "\\\\").replace('"', '\\"')

lines = [
    'var iTerm = Application("iTerm");',
    'iTerm.activate();',
    # Reuse existing empty window if iTerm just opened one, otherwise create new
    'var win;',
    'if (iTerm.windows.length > 0 && iTerm.windows[0].tabs.length === 1) {',
    '  win = iTerm.windows[0];',
    '} else {',
    '  win = iTerm.createWindowWithDefaultProfile();',
    '}',
    # Position window on right half of screen
    'ObjC.import("AppKit");',
    'var screen = $.NSScreen.mainScreen.frame;',
    'var halfW = screen.size.width / 2;',
    'win.bounds = {x: halfW, y: 0, width: halfW, height: screen.size.height};',
    'delay(1);',
]
for i, s in enumerate(sessions):
    name = s["name"]
    path = os.path.expanduser(s["path"])
    resume = s.get("resume") or ""

    title = f"printf '\\e]1;{name}\\a'"
    if resume:
        cmd = f"cd '{path}' && {title} && ({base_cmd} --resume '{resume}' || (echo '⚠ session \"{resume}\" not found — starting fresh' && {base_cmd}))"
    else:
        cmd = f"cd '{path}' && {title} && {base_cmd}"

    if i > 0:
        lines.append('win.createTabWithDefaultProfile();')
    lines.append(f'win.currentSession().name = "{js_esc(name)}";')
    lines.append(f'win.currentSession().write({{text: "{js_esc(cmd)}"}});')

# Select first tab
lines.append('win.tabs[0].select();')

# Auto-confirm: Enter at 5s (channels prompt), Enter at 15s (resume prompt)
lines.append('var tabs = win.tabs;')
lines.append('delay(5);')
lines.append('for (var i = 0; i < tabs.length; i++) {')
lines.append('  tabs[i].currentSession().write({text: ""});')
lines.append('}')
lines.append('delay(10);')
lines.append('for (var i = 0; i < tabs.length; i++) {')
lines.append('  tabs[i].currentSession().write({text: ""});')
lines.append('}')

print("\n".join(lines))
PYEOF
  echo "ccrun: launched $count session(s) in iTerm2"
}

cmd_list() {
  require_jq
  require_config
  (echo "NAME	RUN	PATH	RESUME";
   jq -r '.sessions[] | "\(.name)\t\(if .run == false then "no" else "yes" end)\t\(.path)\t\(.resume // "—")"' "$CONFIG") \
    | column -t -s $'\t'
}

cmd_add() {
  require_jq
  ensure_config_dir
  local name="${2:-}" path="${3:-}" resume="${4:-}"
  if [[ -z "$name" || -z "$path" ]]; then
    echo "ccrun: usage: ccrun add <name> <path> [<resume>]" >&2
    exit 1
  fi
  local tmp
  tmp=$(mktemp)
  if [[ -n "$resume" ]]; then
    jq --arg n "$name" --arg p "$path" --arg r "$resume" \
      '.sessions += [{name:$n, path:$p, resume:$r, run:true}]' "$CONFIG" > "$tmp"
  else
    jq --arg n "$name" --arg p "$path" \
      '.sessions += [{name:$n, path:$p, resume:null, run:true}]' "$CONFIG" > "$tmp"
  fi
  mv "$tmp" "$CONFIG"
  echo "ccrun: added '$name'"
}

cmd_remove() {
  require_jq
  require_config
  local name="${2:-}"
  [[ -z "$name" ]] && { echo "ccrun: usage: ccrun remove <name>" >&2; exit 1; }
  local tmp
  tmp=$(mktemp)
  jq --arg n "$name" '.sessions |= map(select(.name != $n))' "$CONFIG" > "$tmp"
  mv "$tmp" "$CONFIG"
  echo "ccrun: removed '$name'"
}

cmd_eco() {
  require_config
  echo "ccrun: opening $CONFIG"
  mate "$CONFIG"
}

cmd_edit() {
  ensure_config_dir
  "${EDITOR:-code}" "$CONFIG"
}

cmd_path() {
  echo "$CONFIG"
}

case "$SUBCMD" in
  launch|"")    cmd_launch       ;;
  list)         cmd_list         ;;
  add)          cmd_add "$@"     ;;
  remove|rm)    cmd_remove "$@"  ;;
  eco)          cmd_eco          ;;
  edit)         cmd_edit         ;;
  path)         cmd_path         ;;
  -h|--help|help) usage          ;;
  *)            usage; exit 1    ;;
esac
